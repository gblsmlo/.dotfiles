[user]
	name = Gabriel Melo
	email = gmelo@bondingai.io
	signingKey = 
[alias]
	ci = commit
	co = checkout
	cm = checkout main
	cd = checkout develop
	cb = checkout -b
	cs = !git status -s
	cl = !git log --pretty=format:'%C(blue)%h %C(red)%d %C(white)%s - %C(cyan)%cn, %C(green)%cr'
[push]
	followTags = true
[pull]
	rebase = true
[init]
	defaultBranch = main
[commit]
	signingkey = true
	gpgSign = false
[tag]
	signingkey = true
	forceSignAnnotated = false
[core]
	editor = vim
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[safe]
	directory = *
[gpg]
	format = 
	program = gpg
[gpg "ssh"]
	program = 
	allowedSignersFile = 
